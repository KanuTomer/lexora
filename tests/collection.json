{
  "info": {
    "_postman_id": "7ed7eb1c-c22e-44d2-8ac5-7c49ca52a7f4",
    "name": "Lexora Production API Smoke Tests",
    "description": "Critical production API smoke tests for auth, upload authorization, and admin route protection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://lexora-bvpt.onrender.com/api"
    },
    {
      "key": "password",
      "value": "NewmanTest@12345"
    },
    {
      "key": "testUsername",
      "value": ""
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Signup success",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('testUsername', 'ci_test_user');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is correct', function () {",
              "  pm.expect([201, 400]).to.include(pm.response.code);",
              "});",
              "",
              "pm.test('Signup either creates or confirms existing CI user', function () {",
              "  if (pm.response.code === 201) {",
              "    const json = pm.response.json();",
              "    pm.expect(json.data.token).to.be.a('string').and.not.empty;",
              "  } else {",
              "    pm.expect(pm.response.json().message).to.match(/Username|Email/i);",
              "  }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{testUsername}}\",\n  \"email\": \"{{testUsername}}@lexora-ci.local\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/signup",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "signup"
          ]
        }
      }
    },
    {
      "name": "Duplicate username",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is correct', function () {",
              "  pm.response.to.have.status(400);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{testUsername}}\",\n  \"email\": \"{{testUsername}}_duplicate@lexora-ci.local\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/signup",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "signup"
          ]
        }
      }
    },
    {
      "name": "Login success",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is correct', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Login response contains a token', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.data.token).to.be.a('string').and.not.empty;",
              "  pm.collectionVariables.set('token', json.data.token);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{testUsername}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Unauthorized upload with wrong subject",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is correct', function () {",
              "  pm.response.to.have.status(403);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": "tests/fixtures/sample.pdf"
            },
            {
              "key": "title",
              "value": "Newman authorization smoke test",
              "type": "text"
            },
            {
              "key": "subjectId",
              "value": "wrong-subject-id",
              "type": "text"
            },
            {
              "key": "fileType",
              "value": "notes",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/files/upload",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "files",
            "upload"
          ]
        }
      }
    },
    {
      "name": "Admin route protection without token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is correct', function () {",
              "  pm.expect([401, 403]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/admin/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "users"
          ]
        }
      }
    }
  ]
}
